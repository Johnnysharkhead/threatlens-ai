---
import '../styles/global.css'

interface Props {
  title?: string;
  fullWidth?: boolean;
}

const { title = 'AI Attack Vault', fullWidth = false } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="ThreatLens AI — AI网络攻击威胁情报平台" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-[var(--color-bg-primary)] text-[var(--color-text-primary)] font-sans min-h-screen antialiased">

    {!fullWidth && (
      <header class="border-b border-[var(--color-border-default)] sticky top-0 z-50 bg-[var(--color-bg-primary)]">
        <nav class="max-w-[896px] mx-auto px-6 h-14 flex items-center justify-between">
          <a href={import.meta.env.BASE_URL} class="flex items-center gap-2 no-underline">
            <span class="text-base font-bold tracking-tight text-[var(--color-text-primary)]">ThreatLens</span>
            <span class="text-base font-semibold text-[var(--color-accent)] tracking-wide">AI</span>
          </a>
          <span class="text-xs text-[var(--color-text-tertiary)]">Cyber Threat Intelligence</span>
        </nav>
      </header>
    )}

    {fullWidth ? (
      <slot />
    ) : (
      <main class="max-w-[896px] mx-auto px-6 py-10">
        <slot />
      </main>
    )}

    <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js" is:inline></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof mermaid !== 'undefined') {
          mermaid.initialize({
            startOnLoad: true,
            theme: 'base',
            themeVariables: {
              primaryColor: '#FFFFFF',
              primaryBorderColor: '#D1D5DB',
              primaryTextColor: '#111827',
              lineColor: '#D1D5DB',
              secondaryColor: '#F9FAFB',
              tertiaryColor: '#F3F4F6',
              fontFamily: 'Inter, system-ui, sans-serif',
              fontSize: '13px'
            },
            flowchart: {
              curve: 'basis',
              padding: 16
            }
          });
        }
      });
    </script>
  </body>
</html>
